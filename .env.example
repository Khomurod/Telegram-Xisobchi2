BOT_TOKEN=your_bot_token_here
WEBHOOK_URL=https://your-domain.com
WEBHOOK_PATH=/webhook
DATABASE_URL=sqlite+aiosqlite:///./data/xisobchi.db
# For production (Railway PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# Speech-to-Text (currently using Yandex SpeechKit)
YANDEX_API_KEY=your_yandex_api_key_here
# To switch to OpenAI Whisper, set this instead (and update speech_service.py):
# OPENAI_API_KEY=your_openai_api_key_here
# To switch to Google Cloud STT, set these instead:
# GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json
# SPEECH_LANGUAGE=uz-UZ
MAX_VOICE_DURATION=60
VOICE_RATE_LIMIT=10
LOG_LEVEL=INFO
MODE=polling
