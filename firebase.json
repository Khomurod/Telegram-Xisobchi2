{
    "hosting": {
        "public": "docs",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "headers": [
            {
                "source": "**/*.html",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache, no-store, must-revalidate"
                    }
                ]
            }
        ],
        "rewrites": [
            {
                "source": "/app/**",
                "destination": "/app/index.html"
            },
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    }
}